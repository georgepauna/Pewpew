  "_schema": {
    "purpose": "Self-contained baseline of every numeric lever that affects gameplay difficulty and feel. One snapshot = one point in time we can A/B against.",
    "conventions": {
      "fire_rate_sec": "seconds between shots (lower = faster). Reciprocal is shots/sec.",
      "damage_per_bullet": "raw damage applied per projectile hit; player i-frames apply between hits.",
      "speed_px_per_sec": "scalar OR [min, max] when randomized at spawn.",
      "levels": "array length defines max level for that thing. Add/remove entries freely — index = level - 1.",
      "_notes": "free-form comment field. Ignore for diffing semantics."
    }
  },

