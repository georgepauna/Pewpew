{
  "_meta": {
    "snapshot_id": "04-livelier-waves",
    "date": "2026-05-27",
    "source_commit": "(pending)",
    "summary": "Third tuning iteration applied to live. Stacks four sim levers from the snap-03 wave-overlap experiment: incm=0.5 (income halved), cost=2.0 (all upgrades doubled), ehp=2.0 (enemy HP doubled), enemyspd=0.5 (passing + drift speeds halved — kamikaze now drifts longer before lock-on). Together these cut average dead-air per level from ~47% to ~30%, doubled mean enemies on screen, and pushed bad-profile bots to the death cap. The shop UI also gets a new tiered_bar primitive: weapon-level bars now show one segment per tier with vertical sub-level fill, separators that vanish when the segment is full.",
    "diff_from_previous": [
      "income halved: enemy CREDITS x0.5, money pickup 50 -> 25 (snap03 lever incm=0.5).",
      "upgrade costs doubled: MAIN/SIDE upgrade tables x2, MAIN_BUY_COST 1500->3000, SIDE_BUY_COST 800->1600, BOMB_PRICE 250->500, shield/engine tables x2 (snap03 lever cost=2.0).",
      "enemy HP doubled across the board: per-class hp= and boss base 24000->48000 (snap03 lever ehp=2.0).",
      "enemy passing/drift speeds halved (snap03 lever enemyspd=0.5). Kamikaze pre-dive drift slowed; dive itself unchanged.",
      "Shop UI: weapon-level bars use new tiered_bar primitive (5 tiers x 4 sub-levels for main, 3 x 4 for side). Sub-level separators vanish when the tier is filled."
    ],
    "next_snapshot": "Bump to 05-<short-slug>.json.",
    "top_level_levers": [
      "enemy_hp (direct + per-level difficulty multiplier)",
      "enemy_fire_rate + bullets_per_shot + bullet_speed",
      "enemy_speed (no per-level scaling currently)",
      "wave_count, enemies_per_wave, obstacle_density per level",
      "level duration (caps damage exposure window)",
      "player_shield (max_hp, regen, i-frames, regen_delay)",
      "player_engine_speed",
      "weapon_damage_per_bullet, bullets_per_shot, fire_rate per level",
      "side_weapon stats (missile damage, drone fire rate)",
      "ability cooldown + effect magnitude",
      "economy INCOME: credits per enemy (per class), drop_chance + drop_table per enemy, pickup_money_value ($50), boss credits",
      "economy SPENDING: weapon upgrade_cost per level, first_purchase_cost (MAIN/SIDE_BUY_COST), shield/engine costs, BOMB_PRICE",
      "boss hp_base + boss_hp_multiplier curve",
      "enemy unlock thresholds + reweighting tables",
      "sector obstacle composition + wall presence"
    ]
  },
