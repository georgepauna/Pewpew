  "level_scaling": {
    "_notes": "All formulas apply at level n (n=1..100). Each 10th level is a boss level. NO scaling currently exists for enemy speed, fire rate, bullet speed, or player i-frames — those are tuning levers we have not pulled yet.",
    "difficulty_multiplier": {
      "formula": "1.0 + (n - 1) * 0.05",
      "applies_to": [
        "non_boss_enemy_hp"
      ],
      "realized": {
        "n=1": 1.0,
        "n=10": 1.45,
        "n=25": 2.2,
        "n=50": 3.45,
        "n=75": 4.7,
        "n=100": 5.95
      }
    },
    "duration_sec": {
      "formula": "min(45 + n//2, 90)",
      "realized": {
        "n=1": 45,
        "n=25": 57,
        "n=50": 70,
        "n=75": 82,
        "n=100": 90
      }
    },
    "wave_count": {
      "formula": "5 + n // 8",
      "realized": {
        "n=1": 5,
        "n=25": 8,
        "n=50": 11,
        "n=75": 14,
        "n=100": 17
      }
    },
    "enemies_per_wave": {
      "formula": "3 + n // 10",
      "realized": {
        "n=1": 3,
        "n=25": 5,
        "n=50": 8,
        "n=75": 10,
        "n=100": 13
      }
    },
    "obstacle_wave_count": {
      "formula": "3 + n // 15",
      "realized": {
        "n=1": 3,
        "n=25": 4,
        "n=50": 6,
        "n=75": 8,
        "n=100": 9
      }
    },
    "obstacles_per_wave": {
      "formula": "2 + n // 25",
      "realized": {
        "n=1": 2,
        "n=25": 3,
        "n=50": 4,
        "n=75": 5,
        "n=100": 6
      }
    },
    "boss_hp_multiplier": {
      "formula": "max(1.0, 1.0 + ((n - 10) // 10) * 0.35)",
      "applies_to": [
        "boss_hp_only"
      ],
      "realized": {
        "n=10": 1.0,
        "n=20": 1.35,
        "n=50": 2.4,
        "n=100": 4.15
      }
    },
    "unscaled_levers": {
      "enemy_speed": "constant across all levels",
      "enemy_fire_rate": "constant across all levels",
      "enemy_bullet_speed": "constant across all levels (200-230 px/s)",
      "player_iframes": "constant 0.25s",
      "player_shield_regen_delay": "constant 3.0s",
      "kamikaze_dive_speed": "constant 260 px/s"
    }
  },
