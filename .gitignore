__pycache__/
*.pyc
save.json
last_run.log
music_cache/
# Per-machine dev tuning of menu-music layer volumes. The values are
# rolled into the hard-coded layer vol= params by hand later, so the
# JSON itself stays local.
_menu_layer_tuning.json
# Local dev/deploy/probe scaffolding (kept out of the repo by convention).
_*.py
# Editors are shared tools — kept tracked so changes flow with the repo.
!_layout_editor.py
!_sprite_editor.py
_shot_*.png
# Deploy-time BMP conversions of art/sprites/*.png — regenerated by _deploy.py.
art/sprites/*.bmp
# Bot tooling: ignore the per-run artifacts except the plot + meta. Plots
# are tracked so every sim is reviewable in git history; replays and
# telemetry JSONs stay local (too bulky + regeneratable).
tuning/runs/**
!tuning/runs/
!tuning/runs/*/
!tuning/runs/*/progression.png
!tuning/runs/*/meta.json
replays/
.pewpew.pid
perf_*.txt
